# 🌌 OnyxWall — Environment Variables Template
# Copia este archivo como '.env' en entornos locales y configura tus variables.

# ==========================================
# 🧠 INTELIGENCIA ARTIFICIAL (GEMINI SDK)
# ==========================================
# Clave de API de Gemini utilizada para la moderación, validación de estética de imágenes OLED y autotagging.
# En la interfaz de AI Studio, esto se gestiona automáticamente en el panel de Secrets.
# No compartas tus claves ni las expongas en el frontend.
GEMINI_API_KEY=your_gemini_api_key_here

# Claves alternativas que son leídas por el backend como fallback automático de ser necesario:
API_KEY=
GEMINI_KEY=

# ==========================================
# 🔌 CONFIGURACIÓN DE RED Y SERVIDOR
# ==========================================
# El puerto sobre el cual se ejecuta el servidor Express híbrido / SSR.
# El proxy inverso exige que en producción se escuche estrictamente en el puerto 3000.
PORT=3000

# La URL pública principal de la aplicación para control self-referencial y callbacks de redirección.
APP_URL=https://tu-aplicacion.com
