rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'mgwZZrieGtOjPf1GwynoT8ujytZ2' ||
        request.auth.uid == '9yIt0kCQzWS3Odoi1YIHcZrbpJZ2' ||
        ('email' in request.auth.token && (
          request.auth.token.email == 'andressy1126@gmail.com' ||
          request.auth.token.email == 'andresksa123@gmail.com' ||
          request.auth.token.email == 'admin@onyxwall.com' ||
          request.auth.token.email == 'system_admin@onyxwall.com'
        ))
      );
    }

    // Wallpapers Collection
    match /wallpapers/{wallpaperId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Users Profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }
    
    // Favorites Subcollection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }
    
    // Notifications Subcollection
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Audits and Download Request Logs
    match /download_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
